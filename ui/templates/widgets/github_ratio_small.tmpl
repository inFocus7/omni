{{define "widget_github_ratio_small"}}
<div class="widget-fill" style="justify-content:center;text-align:center">
    <p class="section-label">review ratio &middot; {{.Filter}}</p>
    <span class="ratio-number" style="font-size:1.75rem;margin-bottom:0.25rem">{{.Ratio}}</span>
    <div class="ratio-tags">
        <span class="ratio-tag">author</span>
        <span class="ratio-sep">&middot;</span>
        <span class="ratio-tag">reviewer</span>
    </div>
</div>
{{end}}
