<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{block "title" .}}OMNI{{end}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/static/favicon-96x96.png" sizes="96x96">
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
    <link rel="shortcut icon" href="/static/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png">
    <link rel="manifest" href="/static/site.webmanifest">
    <link rel="stylesheet" href="/static/style.css">
    {{block "head" .}}{{end}}
</head>
<body>
    {{block "body" .}}{{end}}

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <div class="footer-col">
                    <span class="footer-col-title">Contact</span>
                    <a href="https://github.com/infocus7" target="_blank" rel="noopener">GitHub</a>
                    <a href="mailto:hello@inf0.dev">Email</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Plugins</span>
                    <a href="https://github.com/infocus7/omni/issues/new?labels=plugin-request" target="_blank" rel="noopener">Request a plugin</a>
                    <a href="/plugins">Browse plugins</a>
                </div>
                <div class="footer-col">
                    <span class="footer-col-title">Contribute</span>
                    <a href="https://github.com/infocus7/omni" target="_blank" rel="noopener">Source code</a>
                    <a href="https://github.com/infocus7/omni/issues" target="_blank" rel="noopener">Report an issue</a>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-left">
                    <span>&copy; 2026 inf0</span>
                </div>
                <img class="footer-icon" src="/static/favicon.svg" alt="OMNI icon">
                <div class="footer-right">
                    <a href="https://github.com/infocus7" target="_blank" rel="noopener">infocus7</a>
                </div>
            </div>
        </div>
    </footer>

    <div id="toast-container" class="toast-container"></div>
    {{block "scripts" .}}
    <script src="/static/app.js"></script>
    {{end}}
</body>
</html>
