{{define "title"}}settings · OMNI{{end}}

{{define "body"}}
    <header class="site-header">
        <a href="/" class="back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            OMNI
        </a>
        <p class="plugin-label" style="margin: 0;">
            <svg class="plugin-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
            <span class="title-text">Settings</span>
        </p>
        <span></span>
    </header>
    <main class="plugins">
        <div class="plugin">

            <nav class="filters" id="filters" aria-label="Settings sections">
                <a href="/settings?section=general" {{if eq .Section "general"}}class="active"{{end}}>general</a>
                <a href="/settings?section=plugins"  {{if eq .Section "plugins"}}class="active"{{end}}>plugins</a>
            </nav>

            {{if eq .Section "general"}}
            <section class="detail-section">
                <p class="section-label">general</p>
                <p class="empty-state">No general settings yet.</p>
            </section>
            {{end}}

            {{if eq .Section "plugins"}}
            <section class="detail-section">
                <p class="section-label">
                    <svg class="plugin-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width: 14px; height: 14px;">
                        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                    github · watched orgs &amp; repos
                </p>
                {{if .Settings.GitHub.Watched}}
                <table class="detail-table" id="watched-table">
                    <thead>
                        <tr>
                            <th data-col="entry">entry</th>
                            <th data-col="type">type</th>
                            <th data-col="action"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{range .Settings.GitHub.Watched}}
                        <tr>
                            <td data-val="{{watchedName .}}"><code class="entry-code">{{watchedName .}}</code></td>
                            <td data-val="{{watchedType .}}"><span class="status-tag status-type-{{watchedType .}}">{{watchedType .}}</span></td>
                            <td class="entry-action">
                                <button class="entry-remove" onclick="removeWatched(this, '{{.}}')" aria-label="Remove {{.}}">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                                    </svg>
                                </button>
                            </td>
                        </tr>
                        {{end}}
                    </tbody>
                </table>
                {{else}}
                <p class="empty-state">No repos or orgs watched yet.</p>
                {{end}}

                <form class="watched-add-form" method="POST" action="/settings/github/watch">
                    <input type="text" name="entry" class="app-input" placeholder="myorg/* or myorg/repo" autocomplete="off" spellcheck="false" aria-label="Repository or organization to watch">
                    <button type="submit" class="back-link" aria-label="Add repository or organization">add</button>
                </form>
            </section>
            {{end}}

        </div>
    </main>
{{end}}

{{define "scripts"}}
    <script>
    async function removeWatched(btn, entry) {
        btn.disabled = true;
        try {
            const res = await fetch('/settings/github/watch/' + encodeURIComponent(entry), { method: 'DELETE' });
            if (res.ok) {
                const row = btn.closest('tr');
                const tbody = row.closest('tbody');
                row.remove();
                if (!tbody.querySelector('tr')) {
                    const table = tbody.closest('table');
                    const p = document.createElement('p');
                    p.className = 'empty-state';
                    p.textContent = 'No repos or orgs watched yet.';
                    table.replaceWith(p);
                }
            } else {
                btn.disabled = false;
            }
        } catch (err) {
            console.error('Failed to remove watched entry:', err);
            btn.disabled = false;
        }
    }
    </script>
    <script src="/static/app.js"></script>
{{end}}
