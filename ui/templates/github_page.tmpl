<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>github · dashie</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <header class="site-header">
        <a href="/" class="back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
            </svg>
            dashie
        </a>
        <p class="plugin-label" style="margin: 0;">
            <svg class="plugin-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
        </p>
        <a href="/settings" class="back-link">settings</a>
    </header>
    <main class="plugins">
        <div class="plugin">

            <nav class="filters" id="filters">
                <a href="/github?filter=1d"  {{if eq .ActiveFilter "1d"}}class="active"{{end}}>1d</a>
                <a href="/github?filter=7d"  {{if eq .ActiveFilter "7d"}}class="active"{{end}}>7d</a>
                <a href="/github?filter=1mo"  {{if eq .ActiveFilter "1mo"}}class="active"{{end}}>1mo</a>
                <a href="/github?filter=ytd" {{if eq .ActiveFilter "ytd"}}class="active"{{end}}>ytd</a>
                <a href="/github?filter=all" {{if eq .ActiveFilter "all"}}class="active"{{end}}>all</a>
            </nav>

            <div class="detail-stats">
                <div class="detail-stat">
                    <span class="detail-stat-num">{{len .OpenPRs}}</span>
                    <span class="detail-stat-label">open</span>
                </div>
                <span class="detail-stat-sep">·</span>
                <div class="detail-stat">
                    <span class="detail-stat-num">{{len .ReviewRequested}}</span>
                    <span class="detail-stat-label stat-label-tip">
                        review debt
                        <span class="tip">open only · closed &amp; merged excluded</span>
                    </span>
                </div>
                <span class="detail-stat-sep">·</span>
                <div class="detail-stat">
                    <span class="detail-stat-num">{{len .AssignedIssues}}</span>
                    <span class="detail-stat-label">assigned</span>
                </div>
                <span class="detail-stat-sep">·</span>
                <div class="detail-stat">
                    <span class="detail-stat-num" data-kind="added">{{.TotalAdded}}</span>
                    <span class="detail-stat-label">added</span>
                </div>
                <span class="detail-stat-sep">·</span>
                <div class="detail-stat">
                    <span class="detail-stat-num" data-kind="removed">{{.TotalRemoved}}</span>
                    <span class="detail-stat-label">removed</span>
                </div>
            </div>

            <div class="section-divider"></div>

            <section class="detail-section" id="open-prs">
                <p class="section-label">open prs</p>
                {{if .OpenPRs}}
                <table class="detail-table" data-sortable>
                    <thead>
                        <tr>
                            <th data-col="title">title</th>
                            <th data-col="repo">repo</th>
                            <th data-col="age" data-sort-default>age</th>
                            <th data-col="status">status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{range .OpenPRs}}
                        <tr>
                            <td data-val="{{.Title}}">
                                <a href="{{.HTMLURL}}" target="_blank" rel="noopener">{{.Title}}</a>
                            </td>
                            <td data-val="{{repoFromURL .RepositoryURL}}"><a class="subtle-link" href="{{repoHTMLURL .RepositoryURL}}" target="_blank" rel="noopener"><img class="icon" src="{{repoAvatarURL .RepositoryURL}}" alt="" loading="lazy">{{repoFromURL .RepositoryURL}}</a></td>
                            <td data-val="{{ageUnix .CreatedAt}}">{{ageStr .CreatedAt}}</td>
                            <td data-val="{{if isDraft .Draft}}draft{{else}}ready{{end}}">
                                {{if isDraft .Draft}}
                                <span class="status-tag status-draft">draft</span>
                                {{else}}
                                <span class="status-tag status-ready">ready</span>
                                {{end}}
                            </td>
                        </tr>
                        {{end}}
                    </tbody>
                </table>
                {{else}}
                <p class="empty-state">no open prs</p>
                {{end}}
            </section>

            <div class="section-divider"></div>

            <section class="detail-section" id="review-debt">
                <p class="section-label">
                    <span class="stat-label-tip">
                        review debt
                        <span class="tip">open only · closed &amp; merged excluded</span>
                    </span>
                </p>
                {{if .ReviewRequested}}
                <table class="detail-table" data-sortable>
                    <thead>
                        <tr>
                            <th data-col="title">title</th>
                            <th data-col="repo">repo</th>
                            <th data-col="author">author</th>
                            <th data-col="age" data-sort-default>age</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{range .ReviewRequested}}
                        <tr>
                            <td data-val="{{.Title}}">
                                <a href="{{.HTMLURL}}" target="_blank" rel="noopener">{{.Title}}</a>
                            </td>
                            <td data-val="{{repoFromURL .RepositoryURL}}"><a class="subtle-link" href="{{repoHTMLURL .RepositoryURL}}" target="_blank" rel="noopener"><img class="icon" src="{{repoAvatarURL .RepositoryURL}}" alt="" loading="lazy">{{repoFromURL .RepositoryURL}}</a></td>
                            <td data-val="{{.User.Login}}"><a class="subtle-link" href="{{.User.GetHTMLURL}}" target="_blank" rel="noopener"><img class="icon icon-avatar" src="{{.User.GetAvatarURL}}" alt="" loading="lazy">{{.User.GetLogin}}</a></td>
                            <td data-val="{{ageUnix .CreatedAt}}">{{ageStr .CreatedAt}}</td>
                        </tr>
                        {{end}}
                    </tbody>
                </table>
                {{else}}
                <p class="empty-state">no pending reviews</p>
                {{end}}
            </section>

            <div class="section-divider"></div>

            <section class="detail-section" id="assigned">
                <p class="section-label">assigned</p>
                {{if .AssignedIssues}}
                <table class="detail-table" data-sortable>
                    <thead>
                        <tr>
                            <th data-col="title">title</th>
                            <th data-col="repo">repo</th>
                            <th data-col="age" data-sort-default>age</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{range .AssignedIssues}}
                        <tr>
                            <td data-val="{{.Title}}">
                                <a href="{{.HTMLURL}}" target="_blank" rel="noopener">{{.Title}}</a>
                            </td>
                            <td data-val="{{repoFromURL .RepositoryURL}}"><a class="subtle-link" href="{{repoHTMLURL .RepositoryURL}}" target="_blank" rel="noopener"><img class="icon" src="{{repoAvatarURL .RepositoryURL}}" alt="" loading="lazy">{{repoFromURL .RepositoryURL}}</a></td>
                            <td data-val="{{ageUnix .CreatedAt}}">{{ageStr .CreatedAt}}</td>
                        </tr>
                        {{end}}
                    </tbody>
                </table>
                {{else}}
                <p class="empty-state">no assigned issues</p>
                {{end}}
            </section>

            {{if .WatchedEntries}}
            <div class="section-divider"></div>

            <section class="detail-section" id="team-prs">
                <p class="section-label">team prs</p>
                {{if .TeamPRs}}
                <table class="detail-table" data-sortable>
                    <thead>
                        <tr>
                            <th data-col="title">title</th>
                            <th data-col="repo">repo</th>
                            <th data-col="author">author</th>
                            <th data-col="age" data-sort-default>age</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{range .TeamPRs}}
                        <tr>
                            <td data-val="{{.Title}}">
                                <a href="{{.HTMLURL}}" target="_blank" rel="noopener">{{.Title}}</a>
                            </td>
                            <td data-val="{{repoFromURL .RepositoryURL}}"><a class="subtle-link" href="{{repoHTMLURL .RepositoryURL}}" target="_blank" rel="noopener"><img class="icon" src="{{repoAvatarURL .RepositoryURL}}" alt="" loading="lazy">{{repoFromURL .RepositoryURL}}</a></td>
                            <td data-val="{{.User.Login}}"><a class="subtle-link" href="{{.User.GetHTMLURL}}" target="_blank" rel="noopener"><img class="icon icon-avatar" src="{{.User.GetAvatarURL}}" alt="" loading="lazy">{{.User.GetLogin}}</a></td>
                            <td data-val="{{ageUnix .CreatedAt}}">{{ageStr .CreatedAt}}</td>
                        </tr>
                        {{end}}
                    </tbody>
                </table>
                {{else}}
                <p class="empty-state">no open team prs</p>
                {{end}}
            </section>
            {{else}}
            <div class="section-divider"></div>
            <section class="detail-section" id="team-prs">
                <p class="section-label">team prs</p>
                <p class="empty-state">
                    <a href="/settings?section=github">Configure watched repos</a> to see team PRs here.
                </p>
            </section>
            {{end}}

        </div>
    </main>
    <script src="/static/app.js"></script>
</body>
</html>
